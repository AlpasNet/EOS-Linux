[Desktop Entry]
Comment=Application for managing and playing games on Steam
Exec=/usr/bin/steam --enable-features=UseOzonePlatform --ozone-platform=wayland %U
GenericName=Application for managing and playing games on Steam
Icon=/home/username/Pictures/icons/eos-linux-steam.png
Name=Steam
NoDisplay=false
Path=
PrefersNonDefaultGPU=false
StartupNotify=true
Terminal=false
TerminalOptions=
Type=Application
X-KDE-SubstituteUID=false
X-KDE-Username=
