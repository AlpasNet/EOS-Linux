   <Filename>org.kde.qrca.desktop</Filename>
   <Filename>spotify_spotify.desktop</Filename>
   <Filename>vlc.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
  <Exclude/>
 </Menu>
</Menu>
